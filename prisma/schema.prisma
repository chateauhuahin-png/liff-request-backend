generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// คำขอเบิกเงิน 1 รายการ = 1 record ที่ไหลผ่านสถานะต่างๆ ตลอดกระบวนการ
// pending_approval -> approved / rejected -> paid -> settled
model Request {
  id             Int      @id @default(autoincrement())
  requestNo      String   @unique

  // ขั้นตอน ① — กรอกโดยผู้ขอเบิก
  requesterName  String
  unit           String
  purpose        String
  category       String
  amount         Decimal  @db.Decimal(12, 2)
  neededDate     DateTime
  note           String?
  attachmentName String?
  attachmentUrl  String?
  lineUserId     String?

  status         String   @default("pending_approval")

  // ขั้นตอน ③ — กรอกโดยเจ้าหน้าที่การเงิน ตอนจ่ายเงินจริง
  paymentMethod     String?
  paidAt            DateTime?
  paymentProofName  String?
  paymentProofUrl   String?
  paidByLineUserId  String?

  // ขั้นตอน ④ — กรอกโดยผู้ขอเบิก ตอนส่งหลักฐานการใช้จ่ายจริงเพื่อปิดเรื่อง
  actualAmount        Decimal? @db.Decimal(12, 2)
  settlementNote      String?
  settlementProofName String?
  settlementProofUrl  String?
  settledAt           DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// เก็บว่า LINE userId ไหนทำหน้าที่อะไร — ลงทะเบียนผ่านการพิมพ์ข้อความคุยกับ OA
// role: "commander" (ผบ.หน่วย ผู้อนุมัติ) | "finance" (เจ้าหน้าที่การเงิน)
model Role {
  id         Int      @id @default(autoincrement())
  role       String   @unique
  lineUserId String
  updatedAt  DateTime @updatedAt
}
