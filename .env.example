# คัดลอกไฟล์นี้เป็น .env สำหรับรันบนเครื่อง (ห้าม commit .env ขึ้น git)

# Connection string ของฐานข้อมูล PostgreSQL (จาก Render > PostgreSQL > Connection string)
DATABASE_URL=

# URL ของหน้าฟอร์ม LIFF ที่ deploy บน Cloudflare (เพื่อกำหนด CORS ให้ยิง API มาได้)
# ตัวอย่าง: https://liff-request-form-financial.chateau-huahin.workers.dev
FRONTEND_ORIGIN=

# true = บังคับตรวจสอบ LIFF access token ทุกคำขอ (แนะนำให้เปิดตอนใช้งานจริง)
# false = ปิดไว้ก่อนระหว่างพัฒนา/ทดสอบ
REQUIRE_LIFF_AUTH=false

# Channel access token ของ LINE OA "ขอเบิกเงิน (ธุรการ)" — ยังไม่ต้องใส่ตอนนี้
# จะใช้ตอนสร้างขั้นตอนที่ ② (ส่ง Flex Message แจ้งผู้อนุมัติ)
LINE_CHANNEL_ACCESS_TOKEN=

# Render จะกำหนดค่านี้ให้อัตโนมัติ ไม่ต้องตั้งเอง
PORT=3000
